{
  "name": "lean-crowd-manifest-repo",
  "private": true,
  "scripts": {
    "dev": "npx --prefix astro astro dev --host 0.0.0.0 --root astro",
    "start": "npx --prefix astro astro dev --host 0.0.0.0 --root astro",
    "build": "npx --prefix astro astro build --root astro",
    "preview": "npx --prefix astro astro preview --host 0.0.0.0 --root astro",
    "astro": "cd astro && npx astro",
    "install:astro": "npm --prefix astro install",
    "install:repo": "npm install",
    "check-links": "linkinator . /da/ --server-root astro/dist --recurse",
    "check-links:files": "node scripts/check-links-with-sources.mjs"
  },
  "devDependencies": {
    "cspell": "^6.28.0",
    "markdownlint-cli2": "^0.11.0",
    "prettier": "^2.8.8",
    "linkinator": "^7.6.1"
  }
}
