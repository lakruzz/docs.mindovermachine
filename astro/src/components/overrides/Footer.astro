---
import Default from '@astrojs/starlight/components/Footer.astro';
import Giscus from '../Giscus.astro';

// Starlight exposes route data via Astro.locals.starlightRoute, not as a prop.
// It may be undefined on non-doc routes (e.g. 404).
const routeData = Astro.locals.starlightRoute as typeof Astro.locals.starlightRoute | undefined;
const entry = routeData?.entry;

// giscus is enabled by default; set `giscus: false` in frontmatter to disable
const giscusEnabled = entry !== undefined && entry.data.giscus !== false;

// Derive locale from the entry id (e.g. "da/about/contact" → "da")
const locale = entry?.id.split('/')[0];
const giscusLang = locale === 'da' ? 'da' : 'en';
---

{giscusEnabled && <Giscus lang={giscusLang} />}
<Default {...Astro.props}><slot /></Default>
